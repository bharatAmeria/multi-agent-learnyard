OPENAI_API_KEY = api key here
MODEL_NAME=gpt-4o
SQLITE_DB_PATH=memory/memory.db

# Phase 9 — LangSmith tracing (optional)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-software-eng-team

# Pipeline tuning
MAX_DEBUG_RETRIES=3
MAX_REVIEW_REVISIONS=3
REVIEW_PASS_THRESHOLD=8.0

# Human approval: true = auto-decide from quality_score (good for Streamlit /
# CI); false = real y/n prompt on the CLI.
AUTO_APPROVE=true
